NOISE_PATTERNS = [
    r"package-lock\.json$", r"yarn\.lock$", r"pnpm-lock\.yaml$",
    r"poetry\.lock$", r"Cargo\.lock$", r"composer\.lock$", r"Gemfile\.lock$",
    r"go\.sum$", r"\.min\.(js|css)$", r"\.map$",
    r"(^|/)vendor/", r"(^|/)node_modules/", r"(^|/)dist/", r"(^|/)build/",
    r"\.svg$", r"\.png$", r"\.jpg$", r"\.jpeg$", r"\.gif$", r"\.ico$",
    r"\.pdf$", r"\.mp4$", r"\.zip$", r"\.tar(\.gz)?$", r"\.lockb$",
    r"\.snap$",
]
NOISE_RE = re.compile("|".join(NOISE_PATTERNS), re.I)

SUBJECT_BINS = [
    ("feat",     re.compile(r"^(feat|add|new|introduc|implement|create|support)", re.I)),
    ("fix",      re.compile(r"^(fix|bug|patch|hotfix|repair|resolve|correct)", re.I)),
    ("refactor", re.compile(r"^(refactor|clean|cleanup|rename|move|reorganiz|simplif|tidy|extract|inline)", re.I)),
    ("docs",     re.compile(r"^(doc|docs|readme|comment)", re.I)),
    ("chore",    re.compile(r"^(chore|bump|deps|dep|update|upgrade|build|ci|release|version)", re.I)),
    ("test",     re.compile(r"^(test|tests|spec|cover)", re.I)),
    ("style",    re.compile(r"^(style|format|lint|prettier|fmt)", re.I)),
    ("revert",   re.compile(r"^(revert|undo|rollback)", re.I)),
    ("merge",    re.compile(r"^merge", re.I)),
]
CONV_RE = re.compile(r"^(feat|fix|chore|refactor|docs|style|test|perf|build|ci|revert)(\([^)]*\))?!?:\s", re.I)
OOPS_RE = re.compile(r"\b(oops|wtf|ugh|argh|finally|whoops|smh|typo|hack|kludge|sigh)\b", re.I)
FIXUP_RE = re.compile(r"^(fixup!|squash!|amend!)", re.I)
PR_MERGE_RE = re.compile(r"^Merge\s+(pull\s+request|PR)\s+#(\d+)", re.I)


def find_repos(root: Path, max_depth: int) -> list[Path]:
    repos = []
    root = root.resolve()
    root_depth = len(root.parts)
    for dirpath, dirnames, _ in os.walk(root):
        d = Path(dirpath)
        depth = len(d.parts) - root_depth
        if depth > max_depth:
            dirnames[:] = []
            continue
        if ".git" in dirnames:
            gitpath = d / ".git"
            if gitpath.is_dir() or gitpath.is_file():
                repos.append(d)
                dirnames[:] = [x for x in dirnames if x != ".git"]
    return sorted(repos)


def run_git(repo: Path, args: list[str], timeout: int) -> str:
    try:
        r = subprocess.run(
            ["git", "-C", str(repo)] + args,
            capture_output=True, text=True, timeout=timeout,
            errors="replace",
        )
        return r.stdout
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return ""


def extract_repo(repo: Path, author_pattern: str, timeout: int) -> tuple[list[tuple], list[tuple]]:
    name = repo.name
    # %P = parent SHAs (space-separated, 2+ means merge); trailer field carries
    # co-authored-by lines joined by 0x1f to keep them on one log line.
    log = run_git(
        repo,
        ["log", "--all", "--extended-regexp", f"--author={author_pattern}",
         "--pretty=format:%H%x09%aI%x09%ae%x09%an%x09%P%x09%s%x09"
         "%(trailers:key=Co-authored-by,valueonly,separator=%x1f)"],
        timeout,
    )
    commits = []
    for line in log.splitlines():
        parts = line.split("\t", 6)
        if len(parts) >= 7:
            sha, iso, email, who, parents, subj, coauthors = parts
        elif len(parts) == 6:
            # older git without trailers support
            sha, iso, email, who, parents, subj = parts
            coauthors = ""
        else:
            continue
        commits.append((name, sha, iso, email, who, parents, subj, coauthors))

    # numstat in a second call (avoids parsing complexity, and skips merges)
    nums = run_git(
        repo,
        ["log", "--all", "--no-merges", "--extended-regexp", f"--author={author_pattern}",
         "--pretty=format:C\t%H\t%aI", "--numstat"],
        timeout,
    )
    loc_rows = []
    cur_sha = cur_iso = None
    for line in nums.splitlines():
        if not line:
            continue
        if line.startswith("C\t"):
            parts = line.split("\t")
            if len(parts) >= 3:
                cur_sha, cur_iso = parts[1], parts[2]
            continue
        parts = line.split("\t", 2)
        if len(parts) < 3 or cur_sha is None:
            continue
        a, d, path = parts
        if a == "-" or d == "-":
            continue
        try:
            add, dele = int(a), int(d)
        except ValueError:
            continue
        loc_rows.append((name, cur_sha, cur_iso, add, dele, path))
    return commits, loc_rows


def author_needles(pattern: str) -> list[str]:
    """Lowercase tokens to match against a blame line's author or email."""
    parts = re.split(r"\\\||\|", pattern)
    return [p.strip().lower() for p in parts if p.strip()]


def blame_repo(repo: Path, needles: list[str], timeout: int) -> dict[int, int]:
    """Count lines in HEAD authored by user, bucketed by their author-year."""
    out = run_git(repo, ["ls-tree", "-r", "HEAD", "--name-only"], timeout)
    if not out:
        return {}
    survived: collections.Counter = collections.Counter()
    files = [f for f in out.splitlines() if f and not NOISE_RE.search(f)]
    for f in files:
        blame = run_git(repo, ["blame", "--porcelain", "HEAD", "--", f], timeout)
        if not blame:
            continue
        meta: dict[str, list] = {}
        counts: collections.Counter = collections.Counter()
        cur_sha: str | None = None
        for line in blame.splitlines():
            if line.startswith("\t"):
                if cur_sha:
                    counts[cur_sha] += 1
                continue
            if not line:
                continue
            head = line.split(" ", 1)[0]
            if len(head) == 40 and all(c in "0123456789abcdef" for c in head):
                cur_sha = head
                meta.setdefault(cur_sha, ["", "", 0])
                continue
            if cur_sha is None:
                continue
            key, _, val = line.partition(" ")
            if key == "author":
                meta[cur_sha][0] = val
            elif key == "author-mail":
                meta[cur_sha][1] = val.strip().lstrip("<").rstrip(">")
            elif key == "author-time":
                try:
                    meta[cur_sha][2] = int(val)
                except ValueError:
                    meta[cur_sha][2] = 0
        for sha, n in counts.items():
            m = meta.get(sha)
            if not m:
                continue
            author, email, t = m
            blob = (author + " " + email).lower()
            if not any(needle in blob for needle in needles):
                continue
            if not t:
                continue
            year = dt.datetime.fromtimestamp(t, dt.timezone.utc).year
            survived[year] += n
    return dict(survived)


def ext_of(path: str) -> str:
    if " => " in path:
        path = path.split(" => ", 1)[1]
    base = os.path.basename(path)
    if "." in base:
        e = base.rsplit(".", 1)[1].lower()
        if 0 < len(e) <= 8 and e.isalnum():
            return e
    return "(none)"


def _build_survival(loc_by_year: dict, survival: dict[int, int]) -> dict:
    """Combine 'lines added per year' with 'lines from year still alive in HEAD'."""
    if not survival:
        return {"enabled": False, "years": [], "added": [], "alive": [], "pct": [],
                "total_added": 0, "total_alive": 0, "overall_pct": 0}
    years = sorted(set(loc_by_year.keys()) | set(survival.keys()))
    added = [loc_by_year.get(y, [0, 0])[0] for y in years]
    alive = [survival.get(y, 0) for y in years]
    pct = [round(100 * a / d, 1) if d else 0 for a, d in zip(alive, added)]
    total_added = sum(added)
    total_alive = sum(alive)
    return {
        "enabled": True,
        "years": years,
        "added": added,
        "alive": alive,
        "pct": pct,
        "total_added": total_added,
        "total_alive": total_alive,
        "overall_pct": round(100 * total_alive / total_added, 1) if total_added else 0,
    }


def percentile(xs: list, p: float) -> float:
    if not xs:
        return 0
    xs = sorted(xs)
    k = (len(xs) - 1) * p / 100.0
    f = int(k)
    c = min(f + 1, len(xs) - 1)
    return xs[f] + (xs[c] - xs[f]) * (k - f)


def circular_mean_hours(hours_list: list[float]) -> float:
    """Mean of values on a 24-hour clock, treating 23 and 0 as adjacent."""
    if not hours_list:
        return 0.0
    angles = [h * 2 * math.pi / 24 for h in hours_list]
    sx = sum(math.sin(a) for a in angles)
    cx = sum(math.cos(a) for a in angles)
    a = math.atan2(sx, cx)
    if a < 0:
        a += 2 * math.pi
    return a * 24 / (2 * math.pi)


def shannon_entropy(counter_like) -> float:
    total = sum(counter_like.values()) if hasattr(counter_like, "values") else sum(counter_like)
    if total == 0:
        return 0.0
    vals = counter_like.values() if hasattr(counter_like, "values") else counter_like
    h = 0.0
    for v in vals:
        if v <= 0:
            continue
        p = v / total
        h -= p * math.log2(p)
    return h


def gini(values: list[float]) -> float:
    if not values:
        return 0.0
    xs = sorted(values)
    n = len(xs)
    s = sum(xs)
    if s == 0:
        return 0.0
    cum = 0.0
    for i, x in enumerate(xs, 1):
        cum += i * x
    return (2 * cum) / (n * s) - (n + 1) / n


def analyze(commits: list[tuple], loc_rows: list[tuple], title: str,
            survival: dict[int, int] | None = None) -> dict:
    # dedupe commits by sha
    seen = set()
    uniq = []
    for c in commits:
        if c[1] in seen:
            continue
        seen.add(c[1])
        uniq.append(c)
    commits = uniq

    parsed = []
    for c in commits:
        try:
            d = dt.datetime.fromisoformat(c[2].replace("Z", "+00:00"))
        except ValueError:
            continue
        # (repo, sha, datetime, email, name, parents, subject, coauthors)
        parsed.append((c[0], c[1], d, c[3], c[4], c[5], c[6], c[7]))
    commits = parsed
    if not commits:
        raise SystemExit("No commits matched. Check --author pattern.")

    total = len(commits)
    hours = [0] * 24
    dows = [0] * 7
    heat = [[0] * 24 for _ in range(7)]
    months = collections.Counter()
    years = collections.Counter()
    repos = collections.Counter()
    day_counter = collections.Counter()

    for repo, sha, d, email, name, parents, subj, coauthors in commits:
        hours[d.hour] += 1
        dows[d.weekday()] += 1
        heat[d.weekday()][d.hour] += 1
        months[(d.year, d.month)] += 1
        years[d.year] += 1
        repos[repo] += 1
        day_counter[d.date()] += 1

    night = sum(hours[h] for h in range(0, 7))
    morning = sum(hours[h] for h in range(7, 12))
    afternoon = sum(hours[h] for h in range(12, 18))
    evening = sum(hours[h] for h in range(18, 24))
    weekend = dows[5] + dows[6]

    top_day, top_day_count = day_counter.most_common(1)[0]

    days_list = sorted(day_counter.keys())
    max_streak = cur_streak = 1
    best_end = days_list[0]
    for i in range(1, len(days_list)):
        if (days_list[i] - days_list[i-1]).days == 1:
            cur_streak += 1
            if cur_streak > max_streak:
                max_streak = cur_streak
                best_end = days_list[i]
        else:
            cur_streak = 1
    streak_start = best_end - dt.timedelta(days=max_streak - 1)

    times = sorted(c[2] for c in commits)
    max_burst = 0
    burst_start = times[0]
    j = 0
    for i in range(len(times)):
        while times[i] - times[j] > dt.timedelta(hours=1):
            j += 1
        c = i - j + 1
        if c > max_burst:
            max_burst = c
            burst_start = times[j]

    longest_gap = max(
        ((times[i] - times[i-1], times[i-1], times[i]) for i in range(1, len(times))),
        key=lambda x: x[0],
    )

    top_repos = repos.most_common(15)

    mkeys = sorted(months.keys())
    month_labels, month_counts = [], []
    cur = dt.date(mkeys[0][0], mkeys[0][1], 1)
    last = dt.date(mkeys[-1][0], mkeys[-1][1], 1)
    while cur <= last:
        month_labels.append(f"{cur.year}-{cur.month:02d}")
        month_counts.append(months.get((cur.year, cur.month), 0))
        cur = dt.date(cur.year + 1, 1, 1) if cur.month == 12 else dt.date(cur.year, cur.month + 1, 1)

    today = dt.date.today()
    start365 = today - dt.timedelta(days=365)
    daily = collections.Counter()
    for c in commits:
        ld = c[2].date()
        if ld >= start365:
            daily[ld] += 1
    daily_labels, daily_counts = [], []
    cur = start365
    while cur <= today:
        daily_labels.append(cur.isoformat())
        daily_counts.append(daily.get(cur, 0))
        cur += dt.timedelta(days=1)

    verbs = collections.Counter()
    for c in commits:
        m = re.match(r"^([A-Za-z]+)", c[6].strip())
        if m:
            verbs[m.group(1).lower()] += 1
    top_verbs = verbs.most_common(12)

    # parents field: space-separated parent SHAs. 2+ parents = merge commit.
    merges = sum(1 for c in commits if len(c[5].split()) >= 2)
    year_items = sorted(years.items())

    first = min(times)
    last_t = max(times)
    span_days = (last_t.date() - first.date()).days
    active_days = len(day_counter)

    # --- sessions: contiguous commits with <= 60 min between them ---
    SESSION_GAP = dt.timedelta(minutes=60)
    sessions = []
    s_start = times[0]
    s_count = 1
    for i in range(1, len(times)):
        if times[i] - times[i - 1] > SESSION_GAP:
            sessions.append((s_start, times[i - 1], s_count))
            s_start = times[i]
            s_count = 1
        else:
            s_count += 1
    sessions.append((s_start, times[-1], s_count))
    session_minutes = [(s[1] - s[0]).total_seconds() / 60.0 for s in sessions]
    session_counts = [s[2] for s in sessions]
    session_buckets = [0, 0, 0, 0, 0]  # <30, 30-60, 60-120, 120-240, 240+
    for m in session_minutes:
        if m < 30:
            session_buckets[0] += 1
        elif m < 60:
            session_buckets[1] += 1
        elif m < 120:
            session_buckets[2] += 1
        elif m < 240:
            session_buckets[3] += 1
        else:
            session_buckets[4] += 1
    longest_session = max(sessions, key=lambda s: (s[1] - s[0]).total_seconds())
    busiest_session = max(sessions, key=lambda s: s[2])
    sessions_per_iso_week = collections.Counter()
    for s in sessions:
        iso = s[0].isocalendar()
        sessions_per_iso_week[(iso[0], iso[1])] += 1

    # --- burstiness: B = (sigma - mu) / (sigma + mu) on inter-commit seconds ---
    inter = [(times[i] - times[i - 1]).total_seconds() for i in range(1, len(times))]
    if inter:
        mu = sum(inter) / len(inter)
        var = sum((x - mu) ** 2 for x in inter) / len(inter)
        sigma = math.sqrt(var)
        burstiness = (sigma - mu) / (sigma + mu) if (sigma + mu) > 0 else 0.0
    else:
        mu = 0.0
        burstiness = 0.0

    # --- chronotype drift: per-year centroid hour, weekend %, evening % ---
    py_hours = collections.defaultdict(list)
    py_first_hours = collections.defaultdict(list)
    py_weekend = collections.defaultdict(lambda: [0, 0])
    py_evening = collections.defaultdict(lambda: [0, 0])
    py_night = collections.defaultdict(lambda: [0, 0])
    first_commit_per_day = {}
    for c in commits:
        d = c[2]
        date = d.date()
        h = d.hour + d.minute / 60.0
        py_hours[d.year].append(h)
        py_weekend[d.year][1] += 1
        if d.weekday() >= 5:
            py_weekend[d.year][0] += 1
        py_evening[d.year][1] += 1
        if 18 <= d.hour < 24:
            py_evening[d.year][0] += 1
        py_night[d.year][1] += 1
        if 0 <= d.hour < 7:
            py_night[d.year][0] += 1
        prev = first_commit_per_day.get(date)
        if prev is None or d < prev:
            first_commit_per_day[date] = d
    for date, dval in first_commit_per_day.items():
        py_first_hours[date.year].append(dval.hour + dval.minute / 60.0)
    chrono_years = sorted(py_hours.keys())
    chrono_centroid = [round(circular_mean_hours(py_hours[y]), 2) for y in chrono_years]
    chrono_first = [round(circular_mean_hours(py_first_hours[y]), 2) for y in chrono_years]
    chrono_weekend = [round(100 * py_weekend[y][0] / py_weekend[y][1], 1) if py_weekend[y][1] else 0
                      for y in chrono_years]
    chrono_evening = [round(100 * py_evening[y][0] / py_evening[y][1], 1) if py_evening[y][1] else 0
                      for y in chrono_years]
    chrono_night = [round(100 * py_night[y][0] / py_night[y][1], 1) if py_night[y][1] else 0
                    for y in chrono_years]

    first_hour_dist = [0] * 24
    for dval in first_commit_per_day.values():
        first_hour_dist[dval.hour] += 1

    # --- repo-concurrency entropy per month ---
    pm_repos = collections.defaultdict(collections.Counter)
    for c in commits:
        d = c[2]
        pm_repos[(d.year, d.month)][c[0]] += 1
    ent_keys = sorted(pm_repos.keys())
    entropy_labels = [f"{y}-{m:02d}" for y, m in ent_keys]
    entropy_values = [round(shannon_entropy(pm_repos[k]), 3) for k in ent_keys]
    py_entropy_acc = collections.defaultdict(list)
    for (y, _m), val in zip(ent_keys, entropy_values):
        py_entropy_acc[y].append(val)
    chrono_repo_entropy = [
        round(sum(py_entropy_acc.get(y, [0])) / max(1, len(py_entropy_acc.get(y, [0]))), 3)
        for y in chrono_years
    ]

    # --- vacations: gaps between active days >= 7 ---
    days_set = sorted(day_counter.keys())
    vacations = []
    for i in range(1, len(days_set)):
        gap = (days_set[i] - days_set[i - 1]).days
        if gap >= 7:
            vacations.append((days_set[i - 1].isoformat(), days_set[i].isoformat(), gap))
    vacations.sort(key=lambda v: v[2], reverse=True)
    top_vacations = vacations[:20]

    # --- repo Gini ---
    repo_gini_val = round(gini(list(repos.values())), 3)

    # --- worst week ever: sliding 7-day window with most commits ---
    if days_set:
        first_day = days_set[0]
        last_day = days_set[-1]
        per_day = {d: day_counter[d] for d in days_set}
        # walk every day in span; sliding 7-day count
        worst_count = 0
        worst_end = first_day
        cur = first_day
        from collections import deque
        win = deque()
        running = 0
        cur = first_day
        while cur <= last_day:
            running += per_day.get(cur, 0)
            win.append(cur)
            while win and (cur - win[0]).days >= 7:
                running -= per_day.get(win.popleft(), 0)
            if running > worst_count:
                worst_count = running
                worst_end = cur
            cur += dt.timedelta(days=1)
        worst_start = worst_end - dt.timedelta(days=6)
        # hours profile during this week
        worst_hours = [0] * 24
        worst_dows = [0] * 7
        worst_repos = collections.Counter()
        worst_total_loc = 0
        for c in commits:
            if worst_start <= c[2].date() <= worst_end:
                worst_hours[c[2].hour] += 1
                worst_dows[c[2].weekday()] += 1
                worst_repos[c[0]] += 1
        worst_week = {
            "start": worst_start.isoformat(),
            "end": worst_end.isoformat(),
            "commits": worst_count,
            "hours": worst_hours,
            "dows": worst_dows,
            "top_repos": worst_repos.most_common(5),
        }
    else:
        worst_week = {"start": "", "end": "", "commits": 0, "hours": [0]*24, "dows": [0]*7, "top_repos": []}

    # --- all-time daily counts for the multi-year calendar ---
    all_daily = {d.isoformat(): n for d, n in day_counter.items()}

    # --- peak-month decoded: which month, then dominant repo/category/size ---
    if months:
        peak_ym, peak_count = months.most_common(1)[0]
        peak_repos = collections.Counter()
        peak_cats = collections.Counter()
        peak_subjs = []
        for c in commits:
            if (c[2].year, c[2].month) == peak_ym:
                peak_repos[c[0]] += 1
                subj = c[6].strip()
                if subj:
                    peak_subjs.append(subj)
                    cat = "other"
                    for label, rx in SUBJECT_BINS:
                        if rx.search(subj):
                            cat = label
                            break
                    peak_cats[cat] += 1
        peak_top_repo = peak_repos.most_common(1)[0] if peak_repos else ("", 0)
        peak_top_cat = peak_cats.most_common(1)[0] if peak_cats else ("", 0)
        # peak month median commit size (using LOC, computed below; defer the lookup)
        peak_month_data = {
            "label": f"{peak_ym[0]}-{peak_ym[1]:02d}",
            "commits": peak_count,
            "top_repo": peak_top_repo[0],
            "top_repo_count": peak_top_repo[1],
            "top_category": peak_top_cat[0],
            "top_category_count": peak_top_cat[1],
            "ym": peak_ym,
        }
    else:
        peak_month_data = {"label": "", "commits": 0, "top_repo": "", "top_repo_count": 0,
                           "top_category": "", "top_category_count": 0, "ym": None}

    # --- timezone migration: modal UTC offset (in hours) per month ---
    tz_per_month = collections.defaultdict(collections.Counter)
    for c in commits:
        off = c[2].utcoffset()
        if off is None:
            continue
        h = off.total_seconds() / 3600.0
        tz_per_month[(c[2].year, c[2].month)][h] += 1
    tz_keys = sorted(tz_per_month.keys())
    tz_labels = [f"{y}-{m:02d}" for y, m in tz_keys]
    tz_modal = [tz_per_month[k].most_common(1)[0][0] for k in tz_keys]
    tz_distinct = sorted({h for c in tz_per_month.values() for h in c})
    # transitions: months where modal differs from previous
    tz_transitions = []
    for i in range(1, len(tz_keys)):
        if tz_modal[i] != tz_modal[i - 1]:
            tz_transitions.append({
                "from": tz_labels[i - 1],
                "to": tz_labels[i],
                "from_offset": tz_modal[i - 1],
                "to_offset": tz_modal[i],
            })

    # --- cold-repo resurrections: per repo, gaps >= 90 days between commits ---
    per_repo_dates = collections.defaultdict(list)
    for c in commits:
        per_repo_dates[c[0]].append(c[2])
    resurrections = []
    repo_lifecycle = []  # (repo, first, last, span_days, peak_month, peak_count)
    for repo, ds in per_repo_dates.items():
        ds = sorted(ds)
        first_d = ds[0]
        last_d = ds[-1]
        # peak month for this repo
        m_count = collections.Counter()
        for d in ds:
            m_count[(d.year, d.month)] += 1
        peak_m, peak_n = m_count.most_common(1)[0]
        repo_lifecycle.append({
            "repo": repo,
            "first": first_d.isoformat(),
            "last": last_d.isoformat(),
            "span_days": (last_d.date() - first_d.date()).days,
            "commits": len(ds),
            "peak": f"{peak_m[0]}-{peak_m[1]:02d}",
            "peak_count": peak_n,
        })
        for i in range(1, len(ds)):
            gap = (ds[i].date() - ds[i - 1].date()).days
            if gap >= 90:
                resurrections.append({
                    "repo": repo,
                    "from": ds[i - 1].date().isoformat(),
                    "to": ds[i].date().isoformat(),
                    "days": gap,
                })
    resurrections.sort(key=lambda r: r["days"], reverse=True)
    repo_lifecycle.sort(key=lambda r: r["span_days"], reverse=True)

    # --- subject classifier: bin each commit subject into one category ---
    cat_counts = collections.Counter()
    cat_per_year = collections.defaultdict(lambda: collections.Counter())
    conv_per_year = collections.defaultdict(lambda: [0, 0])  # [conv, total]
    oops_count = 0
    fixup_count = 0
    revert_count = 0
    pr_count_by_repo = collections.Counter()
    pr_total = 0
    subj_lengths = []
    for c in commits:
        subj = c[6].strip()
        if not subj:
            continue
        subj_lengths.append(len(subj))
        cat = "other"
        for label, rx in SUBJECT_BINS:
            if rx.search(subj):
                cat = label
                break
        cat_counts[cat] += 1
        cat_per_year[c[2].year][cat] += 1
        conv_per_year[c[2].year][1] += 1
        if CONV_RE.search(subj):
            conv_per_year[c[2].year][0] += 1
        if OOPS_RE.search(subj):
            oops_count += 1
        if FIXUP_RE.search(subj):
            fixup_count += 1
        if cat == "revert":
            revert_count += 1
        m = PR_MERGE_RE.search(subj)
        if m:
            pr_count_by_repo[c[0]] += 1
            pr_total += 1

    cat_year_keys = sorted(cat_per_year.keys())
    cat_categories = [b[0] for b in SUBJECT_BINS] + ["other"]
    cat_year_series = {
        cat: [cat_per_year[y].get(cat, 0) for y in cat_year_keys]
        for cat in cat_categories
    }
    conv_years = sorted(conv_per_year.keys())
    conv_pct = [
        round(100 * conv_per_year[y][0] / conv_per_year[y][1], 1) if conv_per_year[y][1] else 0
        for y in conv_years
    ]

    # --- co-authors ---
    coauthor_counter = collections.Counter()
    coauthor_total = 0
    for c in commits:
        if not c[7]:
            continue
        for raw in c[7].split("\x1f"):
            raw = raw.strip()
            if not raw:
                continue
            coauthor_counter[raw] += 1
            coauthor_total += 1
    top_coauthors = coauthor_counter.most_common(15)

    # --- identity timeline: distinct (name, email) with first/last/count ---
    identities = {}
    for c in commits:
        key = (c[4], c[3])  # (name, email)
        first_seen, last_seen, count = identities.get(key, (c[2], c[2], 0))
        if c[2] < first_seen:
            first_seen = c[2]
        if c[2] > last_seen:
            last_seen = c[2]
        identities[key] = (first_seen, last_seen, count + 1)
    identity_rows = sorted(
        [(n, e, fs.isoformat(), ls.isoformat(), ct) for (n, e), (fs, ls, ct) in identities.items()],
        key=lambda r: r[2],
    )

    # LOC
    TEST_RE = re.compile(r"(^|/)(tests?|spec|specs|__tests__|e2e)/|(_test|_spec|\.test|\.spec)\.[a-z0-9]+$", re.I)
    DOCS_RE = re.compile(r"\.(md|mdx|rst|txt|adoc|asciidoc)$", re.I)
    CONFIG_RE = re.compile(r"\.(ya?ml|toml|ini|cfg|conf|json|xml|properties|env)$", re.I)

    commit_add_raw = collections.defaultdict(int)
    commit_del_raw = collections.defaultdict(int)
    commit_add = collections.defaultdict(int)
    commit_del = collections.defaultdict(int)
    commit_meta = {}
    ext_add = collections.Counter()
    repo_add = collections.Counter()
    repo_del = collections.Counter()
    file_touches = collections.Counter()
    file_add = collections.Counter()
    test_by_month = collections.defaultdict(lambda: [0, 0])  # [test_lines, code_lines]
    docs_by_month = collections.defaultdict(int)
    config_by_month = collections.defaultdict(int)
    deepest_path = ""
    deepest_depth = -1

    for repo, sha, iso, add, dele, path in loc_rows:
        commit_add_raw[sha] += add
        commit_del_raw[sha] += dele
        if sha not in commit_meta:
            try:
                commit_meta[sha] = (repo, iso, dt.datetime.fromisoformat(iso.replace("Z", "+00:00")))
            except ValueError:
                continue
        if NOISE_RE.search(path):
            continue
        commit_add[sha] += add
        commit_del[sha] += dele
        ext = ext_of(path)
        ext_add[ext] += add
        repo_add[repo] += add
        repo_del[repo] += dele
        # path-aware bins
        clean_path = path.split(" => ", 1)[1] if " => " in path else path
        depth = clean_path.count("/")
        if depth > deepest_depth:
            deepest_depth = depth
            deepest_path = f"{repo}/{clean_path}"
        file_touches[(repo, clean_path)] += 1
        file_add[(repo, clean_path)] += add
        meta = commit_meta.get(sha)
        if meta:
            ymo = (meta[2].year, meta[2].month)
            if TEST_RE.search(clean_path):
                test_by_month[ymo][0] += add
            else:
                test_by_month[ymo][1] += add
            if DOCS_RE.search(clean_path):
                docs_by_month[ymo] += add
            if CONFIG_RE.search(clean_path):
                config_by_month[ymo] += add

    total_add_raw = sum(commit_add_raw.values())
    total_del_raw = sum(commit_del_raw.values())
    total_add = sum(commit_add.values())
    total_del = sum(commit_del.values())

    if commit_add:
        biggest_sha, biggest_add = max(commit_add.items(), key=lambda kv: kv[1])
        bm = commit_meta.get(biggest_sha, (None, None, None))
        subj_by_sha = {c[1]: c[6] for c in commits}
        biggest = {
            "sha": biggest_sha[:10],
            "add": biggest_add,
            "del": commit_del.get(biggest_sha, 0),
            "when": bm[1] or "",
            "repo": bm[0] or "",
            "subject": (subj_by_sha.get(biggest_sha, "") or "")[:140],
        }
    else:
        biggest = {"sha": "", "add": 0, "del": 0, "when": "", "repo": "", "subject": ""}

    loc_by_month = collections.defaultdict(lambda: [0, 0])
    loc_by_hour = [0] * 24
    loc_by_dow = [0] * 7
    loc_by_year = collections.defaultdict(lambda: [0, 0])
    for sha, add in commit_add.items():
        meta = commit_meta.get(sha)
        if not meta:
            continue
        d = meta[2]
        dele = commit_del.get(sha, 0)
        loc_by_month[(d.year, d.month)][0] += add
        loc_by_month[(d.year, d.month)][1] += dele
        loc_by_hour[d.hour] += add
        loc_by_dow[d.weekday()] += add
        loc_by_year[d.year][0] += add
        loc_by_year[d.year][1] += dele

    loc_month_labels, loc_month_add, loc_month_del = [], [], []
    cur = dt.date(mkeys[0][0], mkeys[0][1], 1)
    last = dt.date(mkeys[-1][0], mkeys[-1][1], 1)
    while cur <= last:
        k = (cur.year, cur.month)
        loc_month_labels.append(f"{cur.year}-{cur.month:02d}")
        a, d_ = loc_by_month.get(k, [0, 0])
        loc_month_add.append(a)
        loc_month_del.append(-d_)
        cur = dt.date(cur.year + 1, 1, 1) if cur.month == 12 else dt.date(cur.year, cur.month + 1, 1)

    top_ext = sorted(ext_add.items(), key=lambda x: x[1], reverse=True)[:12]
    top_repos_loc_pairs = sorted(repo_add.items(), key=lambda x: x[1], reverse=True)[:15]
    top_repos_loc = [(r, a, repo_del.get(r, 0)) for r, a in top_repos_loc_pairs]
    year_loc_items = sorted(loc_by_year.items())

    # enrich peak month with LOC stats now that commit_add exists
    if peak_month_data.get("ym") is not None:
        ym = peak_month_data["ym"]
        peak_sizes = []
        peak_ext = collections.Counter()
        for sha, add in commit_add.items():
            meta = commit_meta.get(sha)
            if not meta:
                continue
            d = meta[2]
            if (d.year, d.month) == ym:
                peak_sizes.append(add)
        for repo, sha, iso, add, dele, path in loc_rows:
            meta = commit_meta.get(sha)
            if not meta:
                continue
            if (meta[2].year, meta[2].month) == ym and not NOISE_RE.search(path):
                peak_ext[ext_of(path)] += add
        peak_month_data["median_commit_size"] = int(statistics.median(peak_sizes)) if peak_sizes else 0
        top_lang = peak_ext.most_common(1)
        peak_month_data["top_language"] = top_lang[0][0] if top_lang else ""
        peak_month_data["top_language_lines"] = top_lang[0][1] if top_lang else 0
        peak_month_data.pop("ym", None)

    # commit-size distribution (additions only, post-noise filter)
    commit_sizes = list(commit_add.values())
    size_buckets = [0, 0, 0, 0, 0, 0]  # 0, 1-10, 11-100, 101-500, 501-2000, 2000+
    for s in commit_sizes:
        if s == 0:
            size_buckets[0] += 1
        elif s <= 10:
            size_buckets[1] += 1
        elif s <= 100:
            size_buckets[2] += 1
        elif s <= 500:
            size_buckets[3] += 1
        elif s <= 2000:
            size_buckets[4] += 1
        else:
            size_buckets[5] += 1
    size_p50 = int(percentile(commit_sizes, 50))
    size_p95 = int(percentile(commit_sizes, 95))
    size_p99 = int(percentile(commit_sizes, 99))

    # median commit size by year
    sizes_per_year = collections.defaultdict(list)
    for sha, add in commit_add.items():
        meta = commit_meta.get(sha)
        if meta:
            sizes_per_year[meta[2].year].append(add)
    median_size_per_year = {y: int(statistics.median(v)) for y, v in sizes_per_year.items() if v}

    # test ratio per month
    test_ratio_labels = sorted(test_by_month.keys())
    test_ratio_values = [
        round(100 * test_by_month[k][0] / (test_by_month[k][0] + test_by_month[k][1]), 1)
        if (test_by_month[k][0] + test_by_month[k][1]) else 0
        for k in test_ratio_labels
    ]
    test_ratio_label_strs = [f"{y}-{m:02d}" for y, m in test_ratio_labels]

    # docs effort per month aligned to existing month axis
    docs_month_series = [docs_by_month.get((y, m), 0) for y, m in mkeys]
    config_month_series = [config_by_month.get((y, m), 0) for y, m in mkeys]
    docs_month_labels = [f"{y}-{m:02d}" for y, m in mkeys]

    # most-touched files (top 25)
    top_files = file_touches.most_common(25)
    top_files_rich = [
        {"repo": r, "path": p, "touches": t, "add": file_add.get((r, p), 0)}
        for (r, p), t in top_files
    ]

    # extension polyglot entropy (Shannon over commit-counts per ext, not LOC)
    ext_commit_counts = collections.Counter()
    for (_r, p), n in file_touches.items():
        ext_commit_counts[ext_of(p)] += n
    ext_entropy = round(shannon_entropy(ext_commit_counts), 3)
    ext_distinct = len([e for e, n in ext_commit_counts.items() if n > 0])

    return {
        "title": title,
        "generated": dt.datetime.now().isoformat(timespec="seconds"),
        "total": total,
        "repos_count": len(repos),
        "first": first.isoformat(),
        "last": last_t.isoformat(),
        "span_days": span_days,
        "active_days": active_days,
        "avg_per_day": round(total / span_days, 2) if span_days else 0,
        "avg_active": round(total / active_days, 2) if active_days else 0,
        "weekend_pct": round(100 * weekend / total, 1),
        "night_pct": round(100 * night / total, 1),
        "morning_pct": round(100 * morning / total, 1),
        "afternoon_pct": round(100 * afternoon / total, 1),
        "evening_pct": round(100 * evening / total, 1),
        "hours": hours, "dows": dows, "heat": heat,
        "top_day": {"date": top_day.isoformat(), "count": top_day_count},
        "streak": {"days": max_streak, "start": streak_start.isoformat(), "end": best_end.isoformat()},
        "burst": {"count": max_burst, "start": burst_start.isoformat()},
        "longest_gap": {"days": longest_gap[0].days, "from": longest_gap[1].isoformat(), "to": longest_gap[2].isoformat()},
        "top_repos": top_repos,
        "month_labels": month_labels, "month_counts": month_counts,
        "daily_labels": daily_labels, "daily_counts": daily_counts,
        "top_verbs": top_verbs,
        "merges": merges,
        "years": year_items,
        "sessions": {
            "count": len(sessions),
            "median_min": round(statistics.median(session_minutes), 1) if session_minutes else 0,
            "p95_min": round(percentile(session_minutes, 95), 1),
            "median_commits": int(statistics.median(session_counts)) if session_counts else 0,
            "p95_commits": int(percentile(session_counts, 95)),
            "buckets": session_buckets,
            "longest": {
                "minutes": round((longest_session[1] - longest_session[0]).total_seconds() / 60, 1),
                "commits": longest_session[2],
                "start": longest_session[0].isoformat(),
            },
            "busiest": {
                "minutes": round((busiest_session[1] - busiest_session[0]).total_seconds() / 60, 1),
                "commits": busiest_session[2],
                "start": busiest_session[0].isoformat(),
            },
        },
        "burstiness": round(burstiness, 3),
        "mean_inter_min": round(mu / 60, 1) if inter else 0,
        "chronotype": {
            "years": chrono_years,
            "centroid_hour": chrono_centroid,
            "first_commit_hour": chrono_first,
            "weekend_pct": chrono_weekend,
            "evening_pct": chrono_evening,
            "night_pct": chrono_night,
            "repo_entropy": chrono_repo_entropy,
        },
        "first_hour_dist": first_hour_dist,
        "repo_entropy": {"labels": entropy_labels, "values": entropy_values},
        "vacations": top_vacations,
        "repo_gini": repo_gini_val,
        "subject_categories": cat_categories,
        "subject_cat_counts": [(c, cat_counts.get(c, 0)) for c in cat_categories],
        "subject_cat_year": {"years": cat_year_keys, "series": cat_year_series},
        "subject_len": {
            "median": int(statistics.median(subj_lengths)) if subj_lengths else 0,
            "p95": int(percentile(subj_lengths, 95)),
            "max": max(subj_lengths) if subj_lengths else 0,
        },
        "conv_commits": {"years": conv_years, "pct": conv_pct},
        "oops_count": oops_count,
        "fixup_count": fixup_count,
        "revert_count": revert_count,
        "pr_total": pr_total,
        "pr_top_repos": pr_count_by_repo.most_common(10),
        "coauthor_total": coauthor_total,
        "coauthor_distinct": len(coauthor_counter),
        "top_coauthors": top_coauthors,
        "identities": identity_rows,
        "timezone": {
            "labels": tz_labels,
            "modal": tz_modal,
            "distinct": tz_distinct,
            "transitions": tz_transitions[:20],
        },
        "resurrections": resurrections[:25],
        "repo_lifecycle": repo_lifecycle[:50],
        "worst_week": worst_week,
        "all_daily": all_daily,
        "peak_month": peak_month_data,
        "loc": {
            "commits_with_data": len(commit_add_raw),
            "total_add_raw": total_add_raw,
            "total_del_raw": total_del_raw,
            "total_add": total_add,
            "total_del": total_del,
            "net": total_add - total_del,
            "biggest": biggest,
            "month_labels": loc_month_labels,
            "month_add": loc_month_add,
            "month_del": loc_month_del,
            "by_hour": loc_by_hour,
            "by_dow": loc_by_dow,
            "top_ext": top_ext,
            "top_repos_loc": top_repos_loc,
            "by_year": [(y, v[0], v[1]) for y, v in year_loc_items],
            "size_buckets": size_buckets,
            "size_p50": size_p50,
            "size_p95": size_p95,
            "size_p99": size_p99,
            "median_size_per_year": sorted(median_size_per_year.items()),
            "test_ratio": {"labels": test_ratio_label_strs, "values": test_ratio_values},
            "docs_month": {"labels": docs_month_labels, "docs": docs_month_series, "config": config_month_series},
            "top_files": top_files_rich,
            "deepest_path": deepest_path,
            "deepest_depth": deepest_depth,
            "ext_entropy": ext_entropy,
            "ext_distinct": ext_distinct,
            "survival": _build_survival(loc_by_year, survival or {}),
        },
    }


