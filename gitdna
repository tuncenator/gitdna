<script>
const D = __DATA__;
const fmt = n => n.toLocaleString();
const fmtSigned = n => (n>=0?"+":"") + n.toLocaleString();
document.getElementById("hdr-title").textContent = D.title;
document.getElementById("hdr-scan").textContent = D.repos_count + " repositories with activity";
document.getElementById("hdr-sub").textContent = D.first.slice(0,10) + " -> " + D.last.slice(0,10);
document.getElementById("f-ts").textContent = D.generated;
document.getElementById("s-total").textContent = fmt(D.total);
document.getElementById("s-span").textContent = D.span_days + " days span, " + D.avg_per_day + "/day avg";
document.getElementById("s-active").textContent = fmt(D.active_days);
document.getElementById("s-avg").textContent = D.avg_active + " commits per active day";
document.getElementById("s-repos").textContent = D.repos_count;
document.getElementById("s-merge").textContent = fmt(D.merges) + " (" + (100*D.merges/D.total).toFixed(1) + "%)";
document.getElementById("p-night").textContent = D.night_pct + "%";
document.getElementById("p-morning").textContent = D.morning_pct + "%";
document.getElementById("p-afternoon").textContent = D.afternoon_pct + "%";
document.getElementById("p-evening").textContent = D.evening_pct + "%";
document.getElementById("p-weekend").textContent = D.weekend_pct + "%";
document.getElementById("burst-n").textContent = D.burst.count;
document.getElementById("burst-t").textContent = "commits in 60 minutes\nstarting " + D.burst.start.replace("T"," ").slice(0,16);
document.getElementById("streak-n").textContent = D.streak.days + "d";
document.getElementById("streak-t").textContent = D.streak.start + " -> " + D.streak.end;
document.getElementById("topday-n").textContent = D.top_day.count;
document.getElementById("topday-t").textContent = "on " + D.top_day.date;
document.getElementById("gap-n").textContent = D.longest_gap.days + "d";
document.getElementById("gap-t").textContent = D.longest_gap.from.slice(0,10) + " -> " + D.longest_gap.to.slice(0,10);

const L = D.loc;
document.getElementById("l-add").textContent = "+" + fmt(L.total_add);
document.getElementById("l-del").textContent = "-" + fmt(L.total_del);
document.getElementById("l-del-sub").textContent = L.total_del ? "ratio add/del: " + (L.total_add/L.total_del).toFixed(2) : "";
document.getElementById("l-net").textContent = fmtSigned(L.net);
document.getElementById("l-net-sub").textContent = L.commits_with_data ? "avg per commit: +" + Math.round(L.total_add/L.commits_with_data).toLocaleString() : "";
document.getElementById("l-raw").textContent = "+" + fmt(L.total_add_raw);
document.getElementById("l-raw-sub").textContent = "-" + fmt(L.total_del_raw) + " incl. locks/vendor/binaries";
document.getElementById("big-n").textContent = L.biggest.add ? "+" + fmt(L.biggest.add) : "-";
document.getElementById("big-t").textContent = L.biggest.repo + "\n" + L.biggest.when.replace("T"," ").slice(0,16) + "\n-" + fmt(L.biggest["del"]) + " lines removed\nsha " + L.biggest.sha;
document.getElementById("big-subj").textContent = L.biggest.subject ? "\u201C" + L.biggest.subject + "\u201D" : "";

{ const t = document.getElementById("t-repos"); D.top_repos.forEach(([n,c]) => { const tr=document.createElement("tr"); tr.innerHTML=`<td>${n}</td><td>${fmt(c)}</td>`; t.appendChild(tr); }); }
{ const t = document.getElementById("t-verbs"); D.top_verbs.forEach(([n,c]) => { const tr=document.createElement("tr"); tr.innerHTML=`<td>${n}</td><td>${fmt(c)}</td>`; t.appendChild(tr); }); }
{ const t = document.getElementById("t-locrepo"); L.top_repos_loc.forEach(([n,a,d]) => { const tr=document.createElement("tr"); tr.innerHTML=`<td>${n}</td><td>+${fmt(a)} / -${fmt(d)}</td>`; t.appendChild(tr); }); }
{ const t = document.getElementById("t-ext"); L.top_ext.forEach(([n,a]) => { const tr=document.createElement("tr"); tr.innerHTML=`<td>.${n}</td><td>+${fmt(a)}</td>`; t.appendChild(tr); }); }

Chart.defaults.color = "#8ea2bd";
Chart.defaults.borderColor = "#1f2a39";
const opt = extra => Object.assign({ plugins:{legend:{display:false}}, scales:{y:{grid:{color:"#1f2a39"}},x:{grid:{display:false}}} }, extra||{});

new Chart(document.getElementById("chart-hour"), { type:"bar", data:{ labels:[...Array(24).keys()].map(h=>h+"h"), datasets:[{ data:D.hours, backgroundColor:"#7cc4ff", borderRadius:4 }]}, options: opt() });
new Chart(document.getElementById("chart-dow"), { type:"bar", data:{ labels:["Mon","Tue","Wed","Thu","Fri","Sat","Sun"], datasets:[{ data:D.dows, backgroundColor:D.dows.map((_,i)=>i>=5?"#ff6b6b":"#5ae0a3"), borderRadius:4 }]}, options: opt() });
new Chart(document.getElementById("chart-month"), { type:"line", data:{ labels:D.month_labels, datasets:[{ data:D.month_counts, borderColor:"#7cc4ff", backgroundColor:"rgba(124,196,255,0.15)", fill:true, tension:0.25, pointRadius:0 }]}, options:{ plugins:{legend:{display:false}}, scales:{y:{grid:{color:"#1f2a39"}},x:{grid:{display:false},ticks:{maxTicksLimit:20}}} }});
new Chart(document.getElementById("chart-daily"), { type:"bar", data:{ labels:D.daily_labels, datasets:[{ data:D.daily_counts, backgroundColor:"#5ae0a3" }]}, options:{ plugins:{legend:{display:false}}, scales:{y:{grid:{color:"#1f2a39"}},x:{grid:{display:false},ticks:{maxTicksLimit:12}}} }});
new Chart(document.getElementById("chart-year"), { type:"bar", data:{ labels:D.years.map(y=>y[0]), datasets:[{ data:D.years.map(y=>y[1]), backgroundColor:"#ffb36b", borderRadius:4 }]}, options: opt() });

new Chart(document.getElementById("chart-locmonth"), { type:"bar", data:{ labels:L.month_labels, datasets:[
  { label:"added", data:L.month_add, backgroundColor:"#5ae0a3", stack:"s" },
  { label:"removed", data:L.month_del, backgroundColor:"#ff6b6b", stack:"s" } ]},
  options:{ plugins:{legend:{labels:{color:"#8ea2bd"}}}, scales:{y:{grid:{color:"#1f2a39"},stacked:true,ticks:{callback:v=>v.toLocaleString()}},x:{grid:{display:false},stacked:true,ticks:{maxTicksLimit:20}}} }});
new Chart(document.getElementById("chart-lochour"), { type:"bar", data:{ labels:[...Array(24).keys()].map(h=>h+"h"), datasets:[{ data:L.by_hour, backgroundColor:"#5ae0a3", borderRadius:4 }]}, options:{ plugins:{legend:{display:false}}, scales:{y:{grid:{color:"#1f2a39"},ticks:{callback:v=>v.toLocaleString()}},x:{grid:{display:false}}} }});
new Chart(document.getElementById("chart-locdow"), { type:"bar", data:{ labels:["Mon","Tue","Wed","Thu","Fri","Sat","Sun"], datasets:[{ data:L.by_dow, backgroundColor:L.by_dow.map((_,i)=>i>=5?"#ff6b6b":"#5ae0a3"), borderRadius:4 }]}, options:{ plugins:{legend:{display:false}}, scales:{y:{grid:{color:"#1f2a39"},ticks:{callback:v=>v.toLocaleString()}},x:{grid:{display:false}}} }});
new Chart(document.getElementById("chart-locyear"), { type:"bar", data:{ labels:L.by_year.map(y=>y[0]), datasets:[
  { label:"added", data:L.by_year.map(y=>y[1]), backgroundColor:"#5ae0a3", stack:"s" },
  { label:"removed", data:L.by_year.map(y=>-y[2]), backgroundColor:"#ff6b6b", stack:"s" } ]},
  options:{ plugins:{legend:{labels:{color:"#8ea2bd"}}}, scales:{y:{grid:{color:"#1f2a39"},stacked:true,ticks:{callback:v=>v.toLocaleString()}},x:{grid:{display:false},stacked:true}} }});

{
  const container = document.getElementById("heat");
  const days = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"];
  container.appendChild(Object.assign(document.createElement("div"), {className:"lbl"}));
  for (let h=0; h<24; h++) { const d=document.createElement("div"); d.className="htop"; d.textContent=h; container.appendChild(d); }
  let mx = 0; for (const row of D.heat) for (const v of row) if (v>mx) mx = v;
  for (let w=0; w<7; w++) {
    const l=document.createElement("div"); l.className="lbl"; l.textContent=days[w]; container.appendChild(l);
    for (let h=0; h<24; h++) {
      const c=document.createElement("div"); c.className="cell";
      const v=D.heat[w][h]; const a=mx?v/mx:0;
      c.style.background=`rgba(124, 196, 255, ${0.08 + a*0.92})`;
      c.title=`${days[w]} ${h}:00 - ${v} commits`;
      container.appendChild(c);
    }
  }
}

// --- sessions ---
{
  const S = D.sessions;
  const perActive = D.active_days ? (S.count/D.active_days).toFixed(2) : "0";
  document.getElementById("ses-n").textContent = fmt(S.count);
  document.getElementById("ses-sub").textContent = perActive + " sessions per active day; mean gap " + D.mean_inter_min + " min between commits";
  document.getElementById("ses-med").textContent = S.median_min + " min";
  document.getElementById("ses-medc").textContent = "your typical coding window. Inside it, median " + S.median_commits + " commits, p95 " + S.p95_commits;
  const longHrs = (S.longest.minutes/60).toFixed(1);
  const longMult = S.median_min > 0 ? (S.longest.minutes/S.median_min).toFixed(0) : "-";
  document.getElementById("ses-long").textContent = longHrs + " h";
  document.getElementById("ses-long-sub").textContent = S.longest.commits + " commits, " + longMult + "x your median, started " + S.longest.start.replace("T"," ").slice(0,16);
  const b = D.burstiness;
  let blabel;
  if (b < 0)        blabel = "more regular than random";
  else if (b < 0.3) blabel = "mostly regular";
  else if (b < 0.6) blabel = "bursty";
  else if (b < 0.8) blabel = "very bursty";
  else              blabel = "extremely bursty";
  document.getElementById("burst-b").textContent = b.toFixed(2);
  document.getElementById("burst-sub").textContent = blabel + ". -1 = clockwork, 0 = random Poisson, 1 = all activity in tight clusters.";
  // session buckets and chart hint
  const totalSes = S.buckets.reduce((a,c)=>a+c,0);
  const bp = i => totalSes ? Math.round(100*S.buckets[i]/totalSes) : 0;
  document.getElementById("sesbuckets-hint").textContent =
    bp(0)+"% under 30 min, "+bp(1)+"% 30-60m, "+bp(2)+"% 1-2h, "+bp(3)+"% 2-4h, "+bp(4)+"% 4h+. Most short sessions = lots of quick check-ins; thick tail = real deep-work blocks.";
  new Chart(document.getElementById("chart-sesbuckets"), { type:"bar", data:{ labels:["<30m","30-60m","1-2h","2-4h",">4h"], datasets:[{ data:S.buckets, backgroundColor:"#7cc4ff", borderRadius:4 }]}, options: opt() });
}

// --- repo concurrency entropy ---
{
  const E = D.repo_entropy;
  const meanEnt = E.values.length ? (E.values.reduce((a,b)=>a+b,0)/E.values.length) : 0;
  const maxEnt  = D.repos_count > 1 ? Math.log2(D.repos_count) : 0;
  document.getElementById("entropy-hint").textContent =
    "Average across all months: " + meanEnt.toFixed(2) +
    " (theoretical max " + maxEnt.toFixed(2) + " across " + D.repos_count + " repos). " +
    "0 = single-repo focus that month; higher = spread across many.";
  new Chart(document.getElementById("chart-entropy"), { type:"line", data:{ labels:E.labels, datasets:[{ data:E.values, borderColor:"#ffb36b", backgroundColor:"rgba(255,179,107,0.18)", fill:true, tension:0.25, pointRadius:0 }]}, options:{ plugins:{legend:{display:false}}, scales:{y:{grid:{color:"#1f2a39"}}, x:{grid:{display:false}, ticks:{maxTicksLimit:18}}} }});
}

// --- first-hour-of-day distribution ---
{
  let totalDays = D.first_hour_dist.reduce((a,b)=>a+b,0);
  let medianHr = 0, acc = 0;
  for (let h=0; h<24; h++) { acc += D.first_hour_dist[h]; if (totalDays && acc >= totalDays/2) { medianHr = h; break; } }
  document.getElementById("firsthour-hint").textContent =
    "When your workday actually starts. Median first-commit hour: " + medianHr + "h on " + fmt(totalDays) + " active days.";
  new Chart(document.getElementById("chart-firsthour"), { type:"bar", data:{ labels:[...Array(24).keys()].map(h=>h+"h"), datasets:[{ data:D.first_hour_dist, backgroundColor:"#5ae0a3", borderRadius:4 }]}, options: opt() });
}

// --- vacations ---
{
  const t = document.getElementById("t-vacations");
  const hint = document.getElementById("vac-hint");
  if (!D.vacations.length) {
    const tr=document.createElement("tr"); tr.innerHTML='<td class="dim">No gaps of 7 or more days.</td>'; t.appendChild(tr);
    hint.textContent = "You committed at least once every 6 days for the entire span.";
  } else {
    D.vacations.forEach(([from,to,days]) => {
      const tr=document.createElement("tr"); tr.innerHTML=`<td>${from} -> ${to}</td><td class="num">${days}d</td>`; t.appendChild(tr);
    });
    const totalOff = D.vacations.reduce((a,v)=>a+v[2],0);
