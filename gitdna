def render(data: dict) -> str:
    payload = json.dumps(data)
    return (HTML_TEMPLATE
            .replace("__DATA__", payload)
            .replace("__TITLE__", data["title"]))


def default_author_pattern() -> str:
    name = subprocess.run(["git", "config", "user.name"], capture_output=True, text=True).stdout.strip()
    email = subprocess.run(["git", "config", "user.email"], capture_output=True, text=True).stdout.strip()
    parts = []
    if email:
        parts.append(email.split("@", 1)[0])
    if name:
        for tok in re.split(r"\s+", name):
            if len(tok) >= 3:
                parts.append(tok)
    seen, out = set(), []
    for p in parts:
        k = p.lower()
        if k not in seen:
            seen.add(k)
            out.append(p)
    return "\\|".join(out) if out else ""


def main() -> int:
    ap = argparse.ArgumentParser(
        description="Scan a directory of git repos and build a personal commit dashboard."
    )
    ap.add_argument("root", nargs="?", default=".", help="directory to scan for .git repositories (default: .)")
    ap.add_argument("-a", "--author", default=None,
                    help="git author pattern (escaped-alternation, e.g. 'alice\\|bob@co.com'). defaults to local git config user.")
    ap.add_argument("-o", "--output", default=None,
                    help="output HTML file (default: <root>/gitdna.html)")
    ap.add_argument("-t", "--title", default=None, help="dashboard title (default: 'Git DNA - <pattern>')")
    ap.add_argument("-d", "--max-depth", type=int, default=6, help="max directory depth to scan (default: 6)")
    ap.add_argument("-j", "--jobs", type=int, default=min(16, (os.cpu_count() or 4) * 2),
                    help="parallel workers (default: 2x CPU, capped at 16)")
    ap.add_argument("--timeout", type=int, default=60, help="per-repo git timeout in seconds (default: 60)")
    ap.add_argument("--open", action="store_true", help="open the output in the default browser when done")
    ap.add_argument("--json", default=None, help="also write the raw analysis JSON to this path")
    args = ap.parse_args()

    if shutil.which("git") is None:
        print("git not found in PATH", file=sys.stderr)
        return 2

    root = Path(args.root).resolve()
    if not root.is_dir():
        print(f"not a directory: {root}", file=sys.stderr)
        return 2

    pattern = args.author or default_author_pattern()
    if not pattern:
        print("could not infer author pattern; pass --author", file=sys.stderr)
        return 2

    output = Path(args.output) if args.output else root / "gitdna.html"
    title = args.title or f"Git DNA - {pattern.replace(chr(92)+'|', ', ')}"

    print(f"scanning {root} (max depth {args.max_depth})", file=sys.stderr)
    repos = find_repos(root, args.max_depth)
    print(f"found {len(repos)} git repositories", file=sys.stderr)
    if not repos:
        print("no repositories found", file=sys.stderr)
        return 1

    all_commits, all_loc = [], []
    done = 0
    with cf.ThreadPoolExecutor(max_workers=args.jobs) as ex:
        futs = {ex.submit(extract_repo, r, pattern, args.timeout): r for r in repos}
        for fut in cf.as_completed(futs):
            r = futs[fut]
            try:
                commits, loc_rows = fut.result()
            except Exception as e:
                print(f"  ! {r.name}: {e}", file=sys.stderr)
                commits, loc_rows = [], []
            all_commits.extend(commits)
            all_loc.extend(loc_rows)
            done += 1
            if done % 10 == 0 or done == len(repos):
                print(f"  [{done}/{len(repos)}] scanned", file=sys.stderr)

    print(f"analyzing {len(all_commits)} commit rows, {len(all_loc)} file-changes", file=sys.stderr)
    data = analyze(all_commits, all_loc, title)

    if args.json:
        Path(args.json).write_text(json.dumps(data, indent=2), encoding="utf-8")
        print(f"wrote {args.json}", file=sys.stderr)

    output.write_text(render(data), encoding="utf-8")
    print(f"wrote {output}", file=sys.stderr)
    print(f"  {data['total']} commits across {data['repos_count']} repos",
          file=sys.stderr)
    print(f"  LOC +{data['loc']['total_add']:,} / -{data['loc']['total_del']:,} (filtered)",
          file=sys.stderr)

    if args.open:
        try:
            subprocess.Popen(["xdg-open", str(output)],
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except Exception:
            pass
    return 0


if __name__ == "__main__":
    sys.exit(main())
