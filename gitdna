#!/usr/bin/env python3
"""gitdna - scan a directory of git repos and build a personal commit dashboard."""
from __future__ import annotations

import argparse
import collections
import concurrent.futures as cf
import datetime as dt
import json
import math
import os
import re
import shutil
import statistics
import subprocess
import sys
from pathlib import Path

NOISE_PATTERNS = [
    r"package-lock\.json$", r"yarn\.lock$", r"pnpm-lock\.yaml$",
    r"poetry\.lock$", r"Cargo\.lock$", r"composer\.lock$", r"Gemfile\.lock$",
    r"go\.sum$", r"\.min\.(js|css)$", r"\.map$",
    r"(^|/)vendor/", r"(^|/)node_modules/", r"(^|/)dist/", r"(^|/)build/",
    r"\.svg$", r"\.png$", r"\.jpg$", r"\.jpeg$", r"\.gif$", r"\.ico$",
    r"\.pdf$", r"\.mp4$", r"\.zip$", r"\.tar(\.gz)?$", r"\.lockb$",
    r"\.snap$",
]
NOISE_RE = re.compile("|".join(NOISE_PATTERNS), re.I)


def find_repos(root: Path, max_depth: int) -> list[Path]:
    repos = []
    root = root.resolve()
    root_depth = len(root.parts)
    for dirpath, dirnames, _ in os.walk(root):
        d = Path(dirpath)
        depth = len(d.parts) - root_depth
        if depth > max_depth:
            dirnames[:] = []
            continue
        if ".git" in dirnames:
            gitpath = d / ".git"
            if gitpath.is_dir() or gitpath.is_file():
                repos.append(d)
                dirnames[:] = [x for x in dirnames if x != ".git"]
    return sorted(repos)


def run_git(repo: Path, args: list[str], timeout: int) -> str:
    try:
        r = subprocess.run(
            ["git", "-C", str(repo)] + args,
            capture_output=True, text=True, timeout=timeout,
            errors="replace",
        )
        return r.stdout
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return ""


def extract_repo(repo: Path, author_pattern: str, timeout: int) -> tuple[list[tuple], list[tuple]]:
    name = repo.name
    # %P = parent SHAs (space-separated, 2+ means merge); trailer field carries
    # co-authored-by lines joined by 0x1f to keep them on one log line.
    log = run_git(
        repo,
        ["log", "--all", "--extended-regexp", f"--author={author_pattern}",
         "--pretty=format:%H%x09%aI%x09%ae%x09%an%x09%P%x09%s%x09"
         "%(trailers:key=Co-authored-by,valueonly,separator=%x1f)"],
        timeout,
    )
    commits = []
    for line in log.splitlines():
        parts = line.split("\t", 6)
        if len(parts) >= 7:
            sha, iso, email, who, parents, subj, coauthors = parts
        elif len(parts) == 6:
            # older git without trailers support
            sha, iso, email, who, parents, subj = parts
            coauthors = ""
        else:
            continue
        commits.append((name, sha, iso, email, who, parents, subj, coauthors))

    # numstat in a second call (avoids parsing complexity, and skips merges)
    nums = run_git(
        repo,
        ["log", "--all", "--no-merges", "--extended-regexp", f"--author={author_pattern}",
         "--pretty=format:C\t%H\t%aI", "--numstat"],
        timeout,
    )
    loc_rows = []
    cur_sha = cur_iso = None
    for line in nums.splitlines():
        if not line:
            continue
        if line.startswith("C\t"):
            parts = line.split("\t")
            if len(parts) >= 3:
                cur_sha, cur_iso = parts[1], parts[2]
            continue
        parts = line.split("\t", 2)
        if len(parts) < 3 or cur_sha is None:
            continue
        a, d, path = parts
        if a == "-" or d == "-":
            continue
        try:
            add, dele = int(a), int(d)
        except ValueError:
            continue
        loc_rows.append((name, cur_sha, cur_iso, add, dele, path))
    return commits, loc_rows


def ext_of(path: str) -> str:
    if " => " in path:
        path = path.split(" => ", 1)[1]
    base = os.path.basename(path)
    if "." in base:
        e = base.rsplit(".", 1)[1].lower()
        if 0 < len(e) <= 8 and e.isalnum():
            return e
    return "(none)"


def percentile(xs: list, p: float) -> float:
    if not xs:
        return 0
    xs = sorted(xs)
    k = (len(xs) - 1) * p / 100.0
    f = int(k)
    c = min(f + 1, len(xs) - 1)
    return xs[f] + (xs[c] - xs[f]) * (k - f)


def circular_mean_hours(hours_list: list[float]) -> float:
    """Mean of values on a 24-hour clock, treating 23 and 0 as adjacent."""
    if not hours_list:
        return 0.0
    angles = [h * 2 * math.pi / 24 for h in hours_list]
    sx = sum(math.sin(a) for a in angles)
    cx = sum(math.cos(a) for a in angles)
    a = math.atan2(sx, cx)
    if a < 0:
        a += 2 * math.pi
    return a * 24 / (2 * math.pi)


def shannon_entropy(counter_like) -> float:
    total = sum(counter_like.values()) if hasattr(counter_like, "values") else sum(counter_like)
    if total == 0:
        return 0.0
    vals = counter_like.values() if hasattr(counter_like, "values") else counter_like
    h = 0.0
    for v in vals:
        if v <= 0:
            continue
        p = v / total
        h -= p * math.log2(p)
    return h


def gini(values: list[float]) -> float:
    if not values:
        return 0.0
    xs = sorted(values)
    n = len(xs)
    s = sum(xs)
    if s == 0:
        return 0.0
    cum = 0.0
    for i, x in enumerate(xs, 1):
        cum += i * x
    return (2 * cum) / (n * s) - (n + 1) / n


def analyze(commits: list[tuple], loc_rows: list[tuple], title: str) -> dict:
    # dedupe commits by sha
    seen = set()
    uniq = []
    for c in commits:
        if c[1] in seen:
            continue
        seen.add(c[1])
        uniq.append(c)
    commits = uniq

    parsed = []
    for c in commits:
        try:
            d = dt.datetime.fromisoformat(c[2].replace("Z", "+00:00"))
        except ValueError:
            continue
        # (repo, sha, datetime, email, name, parents, subject, coauthors)
        parsed.append((c[0], c[1], d, c[3], c[4], c[5], c[6], c[7]))
    commits = parsed
    if not commits:
        raise SystemExit("No commits matched. Check --author pattern.")

    total = len(commits)
    hours = [0] * 24
    dows = [0] * 7
    heat = [[0] * 24 for _ in range(7)]
    months = collections.Counter()
    years = collections.Counter()
    repos = collections.Counter()
    day_counter = collections.Counter()

    for repo, sha, d, email, name, parents, subj, coauthors in commits:
        hours[d.hour] += 1
        dows[d.weekday()] += 1
        heat[d.weekday()][d.hour] += 1
        months[(d.year, d.month)] += 1
        years[d.year] += 1
        repos[repo] += 1
        day_counter[d.date()] += 1

    night = sum(hours[h] for h in range(0, 7))
    morning = sum(hours[h] for h in range(7, 12))
    afternoon = sum(hours[h] for h in range(12, 18))
    evening = sum(hours[h] for h in range(18, 24))
    weekend = dows[5] + dows[6]

    top_day, top_day_count = day_counter.most_common(1)[0]

    days_list = sorted(day_counter.keys())
    max_streak = cur_streak = 1
    best_end = days_list[0]
    for i in range(1, len(days_list)):
        if (days_list[i] - days_list[i-1]).days == 1:
            cur_streak += 1
            if cur_streak > max_streak:
                max_streak = cur_streak
                best_end = days_list[i]
        else:
            cur_streak = 1
    streak_start = best_end - dt.timedelta(days=max_streak - 1)

    times = sorted(c[2] for c in commits)
    max_burst = 0
    burst_start = times[0]
    j = 0
    for i in range(len(times)):
        while times[i] - times[j] > dt.timedelta(hours=1):
            j += 1
        c = i - j + 1
        if c > max_burst:
            max_burst = c
            burst_start = times[j]

    longest_gap = max(
        ((times[i] - times[i-1], times[i-1], times[i]) for i in range(1, len(times))),
        key=lambda x: x[0],
    )

    top_repos = repos.most_common(15)

    mkeys = sorted(months.keys())
    month_labels, month_counts = [], []
    cur = dt.date(mkeys[0][0], mkeys[0][1], 1)
    last = dt.date(mkeys[-1][0], mkeys[-1][1], 1)
    while cur <= last:
        month_labels.append(f"{cur.year}-{cur.month:02d}")
        month_counts.append(months.get((cur.year, cur.month), 0))
        cur = dt.date(cur.year + 1, 1, 1) if cur.month == 12 else dt.date(cur.year, cur.month + 1, 1)

    today = dt.date.today()
    start365 = today - dt.timedelta(days=365)
    daily = collections.Counter()
    for c in commits:
        ld = c[2].date()
        if ld >= start365:
            daily[ld] += 1
    daily_labels, daily_counts = [], []
    cur = start365
    while cur <= today:
        daily_labels.append(cur.isoformat())
        daily_counts.append(daily.get(cur, 0))
        cur += dt.timedelta(days=1)

    verbs = collections.Counter()
    for c in commits:
        m = re.match(r"^([A-Za-z]+)", c[6].strip())
        if m:
            verbs[m.group(1).lower()] += 1
    top_verbs = verbs.most_common(12)

    # parents field: space-separated parent SHAs. 2+ parents = merge commit.
    merges = sum(1 for c in commits if len(c[5].split()) >= 2)
    year_items = sorted(years.items())

    first = min(times)
    last_t = max(times)
    span_days = (last_t.date() - first.date()).days
    active_days = len(day_counter)

    # --- sessions: contiguous commits with <= 60 min between them ---
    SESSION_GAP = dt.timedelta(minutes=60)
    sessions = []
    s_start = times[0]
    s_count = 1
    for i in range(1, len(times)):
        if times[i] - times[i - 1] > SESSION_GAP:
            sessions.append((s_start, times[i - 1], s_count))
            s_start = times[i]
            s_count = 1
        else:
            s_count += 1
    sessions.append((s_start, times[-1], s_count))
    session_minutes = [(s[1] - s[0]).total_seconds() / 60.0 for s in sessions]
    session_counts = [s[2] for s in sessions]
    session_buckets = [0, 0, 0, 0, 0]  # <30, 30-60, 60-120, 120-240, 240+
    for m in session_minutes:
        if m < 30:
            session_buckets[0] += 1
        elif m < 60:
            session_buckets[1] += 1
        elif m < 120:
            session_buckets[2] += 1
        elif m < 240:
            session_buckets[3] += 1
        else:
            session_buckets[4] += 1
    longest_session = max(sessions, key=lambda s: (s[1] - s[0]).total_seconds())
    busiest_session = max(sessions, key=lambda s: s[2])
    sessions_per_iso_week = collections.Counter()
    for s in sessions:
        iso = s[0].isocalendar()
        sessions_per_iso_week[(iso[0], iso[1])] += 1

    # --- burstiness: B = (sigma - mu) / (sigma + mu) on inter-commit seconds ---
    inter = [(times[i] - times[i - 1]).total_seconds() for i in range(1, len(times))]
    if inter:
        mu = sum(inter) / len(inter)
        var = sum((x - mu) ** 2 for x in inter) / len(inter)
        sigma = math.sqrt(var)
        burstiness = (sigma - mu) / (sigma + mu) if (sigma + mu) > 0 else 0.0
    else:
        mu = 0.0
        burstiness = 0.0

    # --- chronotype drift: per-year centroid hour, weekend %, evening % ---
    py_hours = collections.defaultdict(list)
    py_first_hours = collections.defaultdict(list)
    py_weekend = collections.defaultdict(lambda: [0, 0])
    py_evening = collections.defaultdict(lambda: [0, 0])
    first_commit_per_day = {}
    for c in commits:
        d = c[2]
        date = d.date()
        h = d.hour + d.minute / 60.0
        py_hours[d.year].append(h)
        py_weekend[d.year][1] += 1
        if d.weekday() >= 5:
            py_weekend[d.year][0] += 1
        py_evening[d.year][1] += 1
        if d.hour >= 18 or d.hour < 7:
            py_evening[d.year][0] += 1
        prev = first_commit_per_day.get(date)
        if prev is None or d < prev:
            first_commit_per_day[date] = d
    for date, dval in first_commit_per_day.items():
        py_first_hours[date.year].append(dval.hour + dval.minute / 60.0)
    chrono_years = sorted(py_hours.keys())
    chrono_centroid = [round(circular_mean_hours(py_hours[y]), 2) for y in chrono_years]
    chrono_first = [round(circular_mean_hours(py_first_hours[y]), 2) for y in chrono_years]
    chrono_weekend = [round(100 * py_weekend[y][0] / py_weekend[y][1], 1) if py_weekend[y][1] else 0
                      for y in chrono_years]
    chrono_evening = [round(100 * py_evening[y][0] / py_evening[y][1], 1) if py_evening[y][1] else 0
                      for y in chrono_years]

    first_hour_dist = [0] * 24
    for dval in first_commit_per_day.values():
        first_hour_dist[dval.hour] += 1

    # --- repo-concurrency entropy per month ---
    pm_repos = collections.defaultdict(collections.Counter)
    for c in commits:
        d = c[2]
        pm_repos[(d.year, d.month)][c[0]] += 1
    ent_keys = sorted(pm_repos.keys())
    entropy_labels = [f"{y}-{m:02d}" for y, m in ent_keys]
    entropy_values = [round(shannon_entropy(pm_repos[k]), 3) for k in ent_keys]

    # --- vacations: gaps between active days >= 7 ---
    days_set = sorted(day_counter.keys())
    vacations = []
    for i in range(1, len(days_set)):
        gap = (days_set[i] - days_set[i - 1]).days
        if gap >= 7:
            vacations.append((days_set[i - 1].isoformat(), days_set[i].isoformat(), gap))
    vacations.sort(key=lambda v: v[2], reverse=True)
    top_vacations = vacations[:20]

    # --- repo Gini ---
    repo_gini_val = round(gini(list(repos.values())), 3)

    # --- subject classifier: bin each commit subject into one category ---
    SUBJECT_BINS = [
        ("feat",     re.compile(r"^(feat|add|new|introduc|implement|create|support)", re.I)),
        ("fix",      re.compile(r"^(fix|bug|patch|hotfix|repair|resolve|correct)", re.I)),
        ("refactor", re.compile(r"^(refactor|clean|cleanup|rename|move|reorganiz|simplif|tidy|extract|inline)", re.I)),
        ("docs",     re.compile(r"^(doc|docs|readme|comment)", re.I)),
        ("chore",    re.compile(r"^(chore|bump|deps|dep|update|upgrade|build|ci|release|version)", re.I)),
        ("test",     re.compile(r"^(test|tests|spec|cover)", re.I)),
        ("style",    re.compile(r"^(style|format|lint|prettier|fmt)", re.I)),
        ("revert",   re.compile(r"^(revert|undo|rollback)", re.I)),
        ("merge",    re.compile(r"^merge", re.I)),
    ]
    CONV_RE = re.compile(r"^(feat|fix|chore|refactor|docs|style|test|perf|build|ci|revert)(\([^)]*\))?!?:\s", re.I)
    OOPS_RE = re.compile(r"\b(oops|wtf|ugh|argh|finally|whoops|smh|typo|hack|kludge|sigh)\b", re.I)
    FIXUP_RE = re.compile(r"^(fixup!|squash!|amend!)", re.I)
    PR_MERGE_RE = re.compile(r"^Merge\s+(pull\s+request|PR)\s+#(\d+)", re.I)

    cat_counts = collections.Counter()
    cat_per_year = collections.defaultdict(lambda: collections.Counter())
    conv_per_year = collections.defaultdict(lambda: [0, 0])  # [conv, total]
    oops_count = 0
    fixup_count = 0
    revert_count = 0
    pr_count_by_repo = collections.Counter()
    pr_total = 0
    subj_lengths = []
    for c in commits:
        subj = c[6].strip()
        if not subj:
            continue
        subj_lengths.append(len(subj))
        cat = "other"
        for label, rx in SUBJECT_BINS:
            if rx.search(subj):
                cat = label
                break
        cat_counts[cat] += 1
        cat_per_year[c[2].year][cat] += 1
        conv_per_year[c[2].year][1] += 1
        if CONV_RE.search(subj):
            conv_per_year[c[2].year][0] += 1
        if OOPS_RE.search(subj):
            oops_count += 1
        if FIXUP_RE.search(subj):
            fixup_count += 1
        if cat == "revert":
            revert_count += 1
        m = PR_MERGE_RE.search(subj)
        if m:
            pr_count_by_repo[c[0]] += 1
            pr_total += 1

    cat_year_keys = sorted(cat_per_year.keys())
    cat_categories = [b[0] for b in SUBJECT_BINS] + ["other"]
    cat_year_series = {
        cat: [cat_per_year[y].get(cat, 0) for y in cat_year_keys]
        for cat in cat_categories
    }
    conv_years = sorted(conv_per_year.keys())
    conv_pct = [
        round(100 * conv_per_year[y][0] / conv_per_year[y][1], 1) if conv_per_year[y][1] else 0
        for y in conv_years
    ]

    # --- co-authors ---
    coauthor_counter = collections.Counter()
    coauthor_total = 0
    for c in commits:
        if not c[7]:
            continue
        for raw in c[7].split("\x1f"):
            raw = raw.strip()
            if not raw:
                continue
            coauthor_counter[raw] += 1
            coauthor_total += 1
    top_coauthors = coauthor_counter.most_common(15)

    # --- identity timeline: distinct (name, email) with first/last/count ---
    identities = {}
    for c in commits:
        key = (c[4], c[3])  # (name, email)
        first_seen, last_seen, count = identities.get(key, (c[2], c[2], 0))
        if c[2] < first_seen:
            first_seen = c[2]
        if c[2] > last_seen:
            last_seen = c[2]
        identities[key] = (first_seen, last_seen, count + 1)
    identity_rows = sorted(
        [(n, e, fs.isoformat(), ls.isoformat(), ct) for (n, e), (fs, ls, ct) in identities.items()],
        key=lambda r: r[2],
    )

    # LOC
    commit_add_raw = collections.defaultdict(int)
    commit_del_raw = collections.defaultdict(int)
    commit_add = collections.defaultdict(int)
    commit_del = collections.defaultdict(int)
    commit_meta = {}
    ext_add = collections.Counter()
    repo_add = collections.Counter()
    repo_del = collections.Counter()

    for repo, sha, iso, add, dele, path in loc_rows:
        commit_add_raw[sha] += add
        commit_del_raw[sha] += dele
        if sha not in commit_meta:
            try:
                commit_meta[sha] = (repo, iso, dt.datetime.fromisoformat(iso.replace("Z", "+00:00")))
            except ValueError:
                continue
        if NOISE_RE.search(path):
            continue
        commit_add[sha] += add
        commit_del[sha] += dele
        ext = ext_of(path)
        ext_add[ext] += add
        repo_add[repo] += add
        repo_del[repo] += dele

    total_add_raw = sum(commit_add_raw.values())
    total_del_raw = sum(commit_del_raw.values())
    total_add = sum(commit_add.values())
    total_del = sum(commit_del.values())

    if commit_add:
        biggest_sha, biggest_add = max(commit_add.items(), key=lambda kv: kv[1])
        bm = commit_meta.get(biggest_sha, (None, None, None))
        subj_by_sha = {c[1]: c[6] for c in commits}
        biggest = {
            "sha": biggest_sha[:10],
            "add": biggest_add,
            "del": commit_del.get(biggest_sha, 0),
            "when": bm[1] or "",
            "repo": bm[0] or "",
            "subject": (subj_by_sha.get(biggest_sha, "") or "")[:140],
        }
    else:
        biggest = {"sha": "", "add": 0, "del": 0, "when": "", "repo": "", "subject": ""}

    loc_by_month = collections.defaultdict(lambda: [0, 0])
    loc_by_hour = [0] * 24
    loc_by_dow = [0] * 7
    loc_by_year = collections.defaultdict(lambda: [0, 0])
    for sha, add in commit_add.items():
        meta = commit_meta.get(sha)
        if not meta:
            continue
        d = meta[2]
        dele = commit_del.get(sha, 0)
        loc_by_month[(d.year, d.month)][0] += add
        loc_by_month[(d.year, d.month)][1] += dele
        loc_by_hour[d.hour] += add
        loc_by_dow[d.weekday()] += add
        loc_by_year[d.year][0] += add
        loc_by_year[d.year][1] += dele

    loc_month_labels, loc_month_add, loc_month_del = [], [], []
    cur = dt.date(mkeys[0][0], mkeys[0][1], 1)
    last = dt.date(mkeys[-1][0], mkeys[-1][1], 1)
    while cur <= last:
        k = (cur.year, cur.month)
        loc_month_labels.append(f"{cur.year}-{cur.month:02d}")
        a, d_ = loc_by_month.get(k, [0, 0])
        loc_month_add.append(a)
        loc_month_del.append(-d_)
        cur = dt.date(cur.year + 1, 1, 1) if cur.month == 12 else dt.date(cur.year, cur.month + 1, 1)

    top_ext = sorted(ext_add.items(), key=lambda x: x[1], reverse=True)[:12]
    top_repos_loc_pairs = sorted(repo_add.items(), key=lambda x: x[1], reverse=True)[:15]
    top_repos_loc = [(r, a, repo_del.get(r, 0)) for r, a in top_repos_loc_pairs]
    year_loc_items = sorted(loc_by_year.items())

    return {
        "title": title,
        "generated": dt.datetime.now().isoformat(timespec="seconds"),
        "total": total,
        "repos_count": len(repos),
        "first": first.isoformat(),
        "last": last_t.isoformat(),
        "span_days": span_days,
        "active_days": active_days,
        "avg_per_day": round(total / span_days, 2) if span_days else 0,
        "avg_active": round(total / active_days, 2) if active_days else 0,
        "weekend_pct": round(100 * weekend / total, 1),
        "night_pct": round(100 * night / total, 1),
        "morning_pct": round(100 * morning / total, 1),
        "afternoon_pct": round(100 * afternoon / total, 1),
        "evening_pct": round(100 * evening / total, 1),
        "hours": hours, "dows": dows, "heat": heat,
        "top_day": {"date": top_day.isoformat(), "count": top_day_count},
        "streak": {"days": max_streak, "start": streak_start.isoformat(), "end": best_end.isoformat()},
        "burst": {"count": max_burst, "start": burst_start.isoformat()},
        "longest_gap": {"days": longest_gap[0].days, "from": longest_gap[1].isoformat(), "to": longest_gap[2].isoformat()},
        "top_repos": top_repos,
        "month_labels": month_labels, "month_counts": month_counts,
        "daily_labels": daily_labels, "daily_counts": daily_counts,
        "top_verbs": top_verbs,
        "merges": merges,
        "years": year_items,
        "sessions": {
            "count": len(sessions),
            "median_min": round(statistics.median(session_minutes), 1) if session_minutes else 0,
            "p95_min": round(percentile(session_minutes, 95), 1),
